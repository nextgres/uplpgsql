-- an unlabeled EXIT inside a labeled block still targets the enclosing loop
create function exit_unlabeled_in_block() returns int language uplpgsql as $$
declare r int := 0;
begin
  for i in 1..5 loop
    <<b>> begin r := r + 1; exit; end;
  end loop;
  return r;
end; $$;
