-- and a trapped error still traps
create function exc_still_works_after_crossing() returns int language uplpgsql as $$
begin
  begin
    perform 1 / 0;
  exception when division_by_zero then return 42;
  end;
  return 0;
end; $$;
select exc_still_works_after_crossing();
